# Register the user toolchains if --config=kleaf_internal_user_clang_toolchain
# Sync with architecture_constants.bzl
build:kleaf_internal_user_clang_toolchain --extra_toolchains=//prebuilts/clang/host/linux-x86/kleaf:user_android_arm_clang_toolchain
build:kleaf_internal_user_clang_toolchain --extra_toolchains=//prebuilts/clang/host/linux-x86/kleaf:user_android_arm64_clang_toolchain
build:kleaf_internal_user_clang_toolchain --extra_toolchains=//prebuilts/clang/host/linux-x86/kleaf:user_android_i386_clang_toolchain
build:kleaf_internal_user_clang_toolchain --extra_toolchains=//prebuilts/clang/host/linux-x86/kleaf:user_android_riscv64_clang_toolchain
build:kleaf_internal_user_clang_toolchain --extra_toolchains=//prebuilts/clang/host/linux-x86/kleaf:user_android_x86_64_clang_toolchain
build:kleaf_internal_user_clang_toolchain --extra_toolchains=//prebuilts/clang/host/linux-x86/kleaf:user_linux_x86_64_clang_toolchain

# If the user provided clang toolchain has a BUILD file in it, ignore
build:kleaf_internal_user_clang_toolchain --deleted_packages=@kleaf_user_clang_toolchain//clang-user
