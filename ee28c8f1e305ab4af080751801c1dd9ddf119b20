        "id": 1979435
      },
      "writtenOn": "2023-07-10T20:53:38Z",
      "side": 1,
      "message": "I had intended to also change the soong patch to use the \"default_debug_level_x\" string, thinking it\u0027d be more understandable. But I must have missed that change",
      "parentUuid": "a96f1c87_9fb96f1a",
      "range": {
        "startLine": 519,
        "startChar": 3,
        "endLine": 523,
        "endChar": 23
      },
      "revId": "ee28c8f1e305ab4af080751801c1dd9ddf119b20",
